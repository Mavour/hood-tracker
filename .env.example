# ── RPC (same model as unicrit) ──────────────────────────────────
# Priority: RPC_4663 → ROBINHOOD_CHAIN_RPC → public default
#
# Public Robinhood (works without Alchemy):
RPC_4663=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_CHAIN_RPC=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_CHAIN_ID=4663

# Optional Alchemy — ONLY after enabling "Robinhood Mainnet" for the app:
#   https://dashboard.alchemy.com → your app → Networks → enable Robinhood Mainnet
# Then set full URL (or key + USE_ALCHEMY=1):
# ROBINHOOD_CHAIN_RPC=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_API_KEY=YOUR_KEY
# USE_ALCHEMY=1

# Postgres (optional — Docker Compose defaults)
DATABASE_URL=postgresql://hood:hood@localhost:5432/hood_tracker

# Redis (optional)
REDIS_URL=redis://localhost:6379

COINGECKO_API_KEY=

# Contracts (defaults already in config/contracts.ts — unicrit addresses)
NPM_CONTRACT_ADDRESS=0x73991a25c818bf1f1128deaab1492d45638de0d3
UNISWAP_V3_FACTORY_ADDRESS=0x1f7d7550b1b028f7571e69a784071f0205fd2efa

PNL_CACHE_TTL=300
INDEX_STALE_SECONDS=600
RATE_LIMIT_TRACK_PER_HOUR=20
